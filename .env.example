# Copie para .env e preencha. O docker-compose lê este arquivo automaticamente.

# Banco
DB_USER=defi
DB_PASSWORD=defi

# Nó RPC Solana na Alchemy (HTTP + WebSocket) — https://dashboard.alchemy.com
# Crie um app na rede "Solana Mainnet" e use a API key aqui.
ALCHEMY_API_KEY=

# Calendário macro: usa o feed público faireconomy/Forex Factory (sem API key).
# Para usar o mock offline, defina no application.yml: defi.macro.mock-enabled=true
